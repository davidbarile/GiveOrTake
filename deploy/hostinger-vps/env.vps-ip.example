# Build this app with your VPS public IP because Next.js bakes NEXT_PUBLIC_* into the build.
# Replace VPS_IP before building.

# API
NODE_ENV=production
PORT=4000
CORS_ORIGIN=http://VPS_IP
COOKIE_SECURE=false
DATABASE_URL=postgresql://got:CHANGE_ME@127.0.0.1:5432/give_or_take
REDIS_URL=redis://127.0.0.1:6379
SESSION_SECRET=replace-with-a-long-random-secret

# WEB
NEXT_PUBLIC_API_URL=http://VPS_IP/api
NEXT_PUBLIC_WS_URL=http://VPS_IP
